# ---------------------------------------------------------------------------
# Open-Todo (OTD) - Environment Configuration
# Copy this file to `.env` and fill in your values.
# ---------------------------------------------------------------------------

# ---------- Database ----------
# SQLite (default, zero-config)
DATABASE_URL=sqlite:///./otd.db

# MySQL / MariaDB
# pip install pymysql  (or mysqlclient)
# DATABASE_URL=mysql+pymysql://user:password@127.0.0.1:3306/open_todo?charset=utf8mb4

# MySQL via mysqlclient driver
# pip install mysqlclient
# DATABASE_URL=mysql+mysqldb://user:password@127.0.0.1:3306/open_todo?charset=utf8mb4

# PostgreSQL (for reference)
# pip install psycopg2-binary
# DATABASE_URL=postgresql+psycopg2://user:password@127.0.0.1:5432/open_todo

# ---------- SMTP Email ----------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your-email@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_USE_TLS=true
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME=Open-Todo

# ---------- Application ----------
# Base URL for verification links in emails (no trailing slash)
APP_BASE_URL=http://localhost:9000

# ---------- Email Feature Toggles ----------
# Set to "true" to enable email sending; "false" to disable (default: false)
MAIL_ENABLED=false
